    <!-- Client-side logic: icons, dark mode, publication filtering, email copy -->
    <script is:inline>
      (function () {
        function initIcons() {
          if (window.lucide && typeof window.lucide.createIcons === "function") {
            window.lucide.createIcons();
          }
        }
        initIcons();

        // Dark mode toggle (default light; respects only explicit user choice)
        var html = document.documentElement;
        var toggle = document.getElementById("theme-toggle");
        if (toggle) {
          toggle.addEventListener("click", function () {
            html.classList.toggle("dark");
            localStorage.setItem(
              "theme",
              html.classList.contains("dark") ? "dark" : "light",
            );
            initIcons();
          });
        }

        // Copy email to clipboard
        var copyBtn = document.getElementById("copy-email-btn");
        if (copyBtn) {
          copyBtn.addEventListener("click", function () {
            var email = "schen" + "@" + "wcupa.edu";
            var text = document.getElementById("copy-email-text");
            var icon = document.getElementById("mail-icon");
            navigator.clipboard
              .writeText(email)
              .then(function () {
                if (text) text.textContent = "Copied!";
                if (icon) {
                  icon.setAttribute("data-lucide", "check");
                  initIcons();
                }
                setTimeout(function () {
                  if (text) text.textContent = "Mail";
                  if (icon) {
                    icon.setAttribute("data-lucide", "mail");
                    initIcons();
                  }
                }, 2000);
              })
              .catch(function () {
                window.location.href = "mailto:" + email;
              });
          });
        }

        // Highlight "Si Chen" in publication authors
        document.querySelectorAll(".publication-author").forEach(function (el) {
          el.innerHTML = el.innerHTML.replace(
            /\bSi Chen\b/g,
            '<span class="highlight-author">Si Chen</span>',
          );
        });

        // Client-side publication filtering
        var typeSel = document.getElementById("filter-type");
        var yearSel = document.getElementById("filter-year");
        var searchInp = document.getElementById("filter-search");
        var showAllChk = document.getElementById("filter-showall");
        var empty = document.getElementById("pub-empty");
        var items = Array.prototype.slice.call(
          document.querySelectorAll(".publication-item"),
        );

        function applyFilters() {
          var t = typeSel ? typeSel.value : "";
          var y = yearSel ? yearSel.value : "";
          var q = searchInp ? searchInp.value.trim().toLowerCase() : "";
          var showAll = showAllChk ? showAllChk.checked : false;
          var visibleCount = 0;
          items.forEach(function (el) {
            var entryType = el.getAttribute("data-type") || "";
            var entryYear = el.getAttribute("data-year") || "";
            var entryHidden = el.getAttribute("data-hidden") === "1";
            var entrySearch = el.getAttribute("data-search") || "";
            var show = true;
            if (!showAll && entryHidden) show = false;
            if (show && t && entryType !== t) show = false;
            if (show && y && entryYear !== y) show = false;
            if (show && q && entrySearch.indexOf(q) === -1) show = false;
            el.style.display = show ? "" : "none";
            if (show) visibleCount++;
          });
          if (empty) empty.style.display = visibleCount === 0 ? "" : "none";
        }

        if (typeSel) typeSel.addEventListener("change", applyFilters);
        if (yearSel) yearSel.addEventListener("change", applyFilters);
        if (searchInp) {
          var searchTimer;
          searchInp.addEventListener("input", function () {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(applyFilters, 200);
          });
        }
        if (showAllChk) showAllChk.addEventListener("change", applyFilters);
        applyFilters();
      })();
    </script>

